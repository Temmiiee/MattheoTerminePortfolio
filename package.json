{
  "name": "mattheo-termine-portfolio",
  "version": "1.0.0",
  "description": "Portfolio de Matthéo Termine — Intégrateur Web Fullstack & Accessibilité RGAA",
  "scripts": {
    "prepare": "husky install",
    "start": "serve -s . -l 3000",
    "lint:html": "html-validate \"**/*.html\"",
    "lint:css": "stylelint \"**/*.css\"",
    "format": "prettier --write \"**/*.{html,css,md,json,js}\"",
    "test:a11y": "pa11y-ci",
    "ci": "npm run lint:html && npm run lint:css && npm run test:a11y"
  },
  "devDependencies": {
    "html-validate": "^7.6.7",
    "husky": "^8.0.0",
    "lint-staged": "^16.2.7",
    "pa11y-ci": "^4.0.1",
    "prettier": "^2.8.8",
    "serve": "^14.2.5",
    "stylelint": "^17.1.0",
    "stylelint-config-standard": "^40.0.0",
    "wait-on": "^9.0.3"
  },
  "lint-staged": {
    "*.{js,css,html,json,md}": [
      "prettier --write"
    ],
    "*.html": [
      "html-validate --reset"
    ],
    "*.css": [
      "stylelint --fix"
    ]
  },
  "author": "Matthéo Termine",
  "license": "MIT"
}
